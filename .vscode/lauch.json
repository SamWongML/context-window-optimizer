{
	"version": "0.2.0",
	"configurations": [
		{
			"type": "lldb",
			"request": "launch",
			"name": "CLI: pack current dir",
			"cargo": {
				"args": ["build", "--bin=ctx-optim", "--features=full"]
			},
			"args": [
				"pack",
				"--budget",
				"128000",
				"--repo",
				"${workspaceFolder}"
			],
			"cwd": "${workspaceFolder}",
			"env": { "RUST_LOG": "debug" }
		},
		{
			"type": "lldb",
			"request": "launch",
			"name": "Debug all tests",
			"cargo": {
				"args": ["test", "--no-run", "--all-features"],
				"filter": { "kind": "lib" }
			},
			"cwd": "${workspaceFolder}"
		}
	]
}
